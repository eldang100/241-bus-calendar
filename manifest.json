// ── KIS 토큰 ─────────────────────────────────────────────────────────────
async function getToken(env) {
  const cached = await env.KV.get("kis_token");
  if (cached) return cached;
  const res = await fetch(`${KIS_BASE}/oauth2/tokenP`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ grant_type:"client_credentials", appkey:APP_KEY, appsecret:APP_SECRET }),
  });
  const data = await res.json();
  const token = data.access_token;
  await env.KV.put("kis_token", token, { expirationTtl: (data.expires_in||86400)-600 });
  return token;
}

// ── 외국인/기관 수급 조회 ────────────────────────────────────────────────
async function getSupply(symbol, env) {
  const token = await getToken(env);

  // 외국인/기관 순매수 (당일 투자자별 매매동향)
  const res = await fetch(
    `${KIS_BASE}/uapi/domestic-stock/v1/quotations/inquire-investor?FID_COND_MRKT_DIV_CODE=J&FID_INPUT_ISCD=${symbol}`,
    {
      headers: {
        "authorization": `Bearer ${token}`,
        "appkey": APP_KEY,
        "appsecret": APP_SECRET,
        "tr_id": "FHKST01010900",
        "content-type": "application/json; charset=utf-8",
      },
    }
  );
  const data = await res.json();
  const out = data.output || [];

  // 당일 데이터 (첫 번째 행)
  const today = out[0] || {};

  const foreignNet  = Number(today.frgn_ntby_qty  || 0); // 외국인 순매수수량
  const instNet     = Number(today.orgn_ntby_qty   || 0); // 기관 순매수수량
  const indivNet    = Number(today.indv_ntby_qty   || 0); // 개인 순매수수량

  const foreignAmt  = Number(today.frgn_ntby_tr_pbmn || 0); // 외국인 순매수금액(백만)
  const instAmt     = Number(today.orgn_ntby_tr_pbmn  || 0);
  const indivAmt    = Number(today.indv_ntby_tr_pbmn  || 0);

  // 비율 계산 (절대값 합 기준)
  const total = Math.abs(foreignAmt) + Math.abs(instAmt) + Math.abs(indivAmt) || 1;
  const fPct  = Math.round(Math.abs(foreignAmt) / total * 100);
  const iPct  = Math.round(Math.abs(instAmt)    / total * 100);
  const pPct  = Math.max(100 - fPct - iPct, 0);

  return {
    foreign:     { pct: fPct, net: Math.round(foreignAmt / 100) }, // 억원
    institution: { pct: iPct, net: Math.round(instAmt    / 100) },
    individual:  { pct: pPct, net: Math.round(indivAmt   / 100) },
  };
}

// ── 종목 검색 ─────────────────────────────────────────────────────────────
async function searchStock(query, env) {
  const token = await getToken(env);
  // KIS 종목 검색 API
  const res = await fetch(
    `${KIS_BASE}/uapi/domestic-stock/v1/quotations/search-stock-info?PRDT_TYPE_CD=300&PDNO=${encodeURIComponent(query)}`,
    {
      headers: {
        "authorization": `Bearer ${token}`,
        "appkey": APP_KEY,
        "appsecret": APP_SECRET,
        "tr_id": "CTPF1002R",
        "content-type": "application/json; charset=utf-8",
      },
    }
  );
  const data = await res.json();
  // 결과 정리
  const items = (data.output||[]).map(item => ({
    code: item.pdno || item.shtn_pdno,
    name: item.prdt_abrv_name || item.prdt_name,
    market: item.mket_id_cd==="STK"?"코스피":"코스닥",
    sector: item.bstp_kor_isnm || "기타",
  })).filter(i=>i.code&&i.name);
  return items;
}

// ── 주가/지수 조회 ────────────────────────────────────────────────────────
async function getPrice(symbol, env) {
  const token = await getToken(env);
  const isIndex = symbol==="0001"||symbol==="1001";
  const url = isIndex
    ? `${KIS_BASE}/uapi/domestic-stock/v1/quotations/inquire-index-price?FID_COND_MRKT_DIV_CODE=U&FID_INPUT_ISCD=${symbol}`
    : `${KIS_BASE}/uapi/domestic-stock/v1/quotations/inquire-price?FID_COND_MRKT_DIV_CODE=J&FID_INPUT_ISCD=${symbol}`;
  const trId = isIndex ? "FHPUP02100000" : "FHKST01010100";
  const res = await fetch(url, {
    headers: { "authorization":`Bearer ${token}`, "appkey":APP_KEY, "appsecret":APP_SECRET, "tr_id":trId, "content-type":"application/json; charset=utf-8" },
  });
  const data = await res.json();
  if (isIndex) return { price:Number(data.output?.bstp_nmix_prpr||0), change_pct:Number(data.output?.bstp_nmix_prdy_ctrt||0), volume:Number(data.output?.acml_tr_pbmn||0) };
  return data;
}

// ── RSS 뉴스 프록시 ──────────────────────────────────────────────────────
async function handleNews(type) {
  const feeds = {
    kr: ["https://www.hankyung.com/feed/finance","https://www.mk.co.kr/rss/40300001/"],
    us: ["https://feeds.reuters.com/reuters/businessNews","https://feeds.a.dj.com/rss/RSSMarketsMain.xml"],
  };
  const urls = feeds[type||"kr"] || feeds.kr;
  const allItems = [];
  for (const feedUrl of urls) {
    try {
      const res = await fetch(feedUrl, { headers:{"User-Agent":"Mozilla/5.0"} });
      const xml = await res.text();
      const items = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)];
      for (const m of items.slice(0,7)) {
        const block=m[1];
        const title=(block.match(/<title><!\[CDATA\[(.*?)\]\]><\/title>/)||block.match(/<title>(.*?)<\/title>/))?.[1]||"";
        const desc=(block.match(/<description><!\[CDATA\[(.*?)\]\]><\/description>/)||block.match(/<description>(.*?)<\/description>/))?.[1]||"";
        const link=(block.match(/<link>(.*?)<\/link>/))?.[1]||"";
        const date=(block.match(/<pubDate>(.*?)<\/pubDate>/))?.[1]||"";
        if(title) allItems.push({title:title.trim(),description:desc.trim(),link:link.trim(),pubDate:date.trim()});
      }
    } catch(e){}
  }
  return new Response(JSON.stringify({items:allItems.slice(0,15)}),
    {headers:{...CORS,"Content-Type":"application/json"}});
}

// ── Cloudflare AI 프록시 ─────────────────────────────────────────────────
async function handleAI(request, env) {
  try {
    const {prompt,type}=await request.json();
    const sysMap={
      chart:"주식 기술적 분석 전문가. RSI와 지지저항 기반으로 한국어로 분석.",
      sector:"한국 주식 섹터 분석 전문가. 섹터 동향을 한국어로 분석.",
      stock:"한국 주식 애널리스트. 종목 분석을 한국어로 간결하게.",
    };
    const aiRes=await env.AI.run("@cf/meta/llama-3.1-8b-instruct",{
      messages:[{role:"system",content:sysMap[type]||"한국어로 답변."},{role:"user",content:prompt}],
      max_tokens:800,
    });
    return new Response(JSON.stringify({content:[{type:"text",text:aiRes.response||""}]}),
      {headers:{...CORS,"Content-Type":"application/json"}});
  } catch(e){
    return new Response(JSON.stringify({content:[{type:"text",text:""}],error:e.message}),
      {status:500,headers:{...CORS,"Content-Type":"application/json"}});
  }
}

// ── 메인 ──────────────────────────────────────────────────────────────────
export default {
  async fetch(request, env) {
    if(request.method==="OPTIONS") return new Response(null,{headers:CORS});
    const url=new URL(request.url);

    if(url.pathname==="/ai"&&request.method==="POST") return handleAI(request,env);
    if(url.pathname==="/news") return handleNews(url.searchParams.get("type"));

    // 수급 조회
    if(url.pathname==="/supply") {
      const symbol=url.searchParams.get("symbol");
      if(!symbol) return new Response(JSON.stringify({error:"symbol 필요"}),{headers:{...CORS,"Content-Type":"application/json"}});
      try{
        const data=await getSupply(symbol,env);
        return new Response(JSON.stringify(data),{headers:{...CORS,"Content-Type":"application/json"}});
      }catch(e){
        return new Response(JSON.stringify({error:e.message}),{status:500,headers:{...CORS,"Content-Type":"application/json"}});
      }
    }

    // 종목 검색
    if(url.pathname==="/search") {
      const q=url.searchParams.get("q")||"";
      if(!q) return new Response(JSON.stringify({items:[]}),{headers:{...CORS,"Content-Type":"application/json"}});
      try {
        const items=await searchStock(q,env);
        return new Response(JSON.stringify({items}),{headers:{...CORS,"Content-Type":"application/json"}});
      } catch(e){
        return new Response(JSON.stringify({items:[],error:e.message}),{headers:{...CORS,"Content-Type":"application/json"}});
      }
    }

    // 주가 조회
    const symbol=url.searchParams.get("symbol");
    if(!symbol) return new Response(JSON.stringify({error:"symbol 필요"}),{headers:{...CORS,"Content-Type":"application/json"}});
    try {
      const data=await getPrice(symbol,env);
      const out={
        symbol,
        name:data.output?.hts_kor_isnm||"",
        price:Number(data.output?.stck_prpr||data.price||0),
        change_pct:Number(data.output?.prdy_ctrt||data.change_pct||0),
        change_amt:Number(data.output?.prdy_vrss||0),
        volume:Number(data.output?.acml_vol||data.volume||0),
        high:Number(data.output?.stck_hgpr||0),
        low:Number(data.output?.stck_lwpr||0),
        open:Number(data.output?.stck_oprc||0),
      };
      return new Response(JSON.stringify(out),{headers:{...CORS,"Content-Type":"application/json"}});
    } catch(e){
      return new Response(JSON.stringify({error:e.message}),{status:500,headers:{...CORS,"Content-Type":"application/json"}});
    }
  },
};
